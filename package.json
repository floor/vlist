{
  "name": "@floor/vlist",
  "version": "1.4.5",
  "description": "Lightweight, high-performance virtual list with zero dependencies",
  "author": {
    "name": "Floor IO",
    "url": "https://floor.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floor/vlist.git"
  },
  "keywords": [
    "virtual-list",
    "virtual-scroll",
    "virtualized-list",
    "infinite-scroll",
    "windowing",
    "list-virtualization",
    "dom-recycling",
    "large-list",
    "performance",
    "typescript",
    "zero-dependencies"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internals": {
      "types": "./dist/internals.d.ts",
      "import": "./dist/internals.js",
      "default": "./dist/internals.js"
    },
    "./styles": "./dist/vlist.css",
    "./styles/grid": "./dist/vlist-grid.css",
    "./styles/masonry": "./dist/vlist-masonry.css",
    "./styles/table": "./dist/vlist-table.css",
    "./styles/extras": "./dist/vlist-extras.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/index.js",
    "dist/internals.js",
    "dist/**/*.d.ts",
    "dist/**/*.css",
    "dist/size.json",
    "!dist/**/*.d.ts.map"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run build.ts --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "size": "bun run scripts/measure-size.ts",
    "prepublishOnly": "bun run build --types"
  },
  "bugs": {
    "url": "https://github.com/floor/vlist/issues"
  },
  "homepage": "https://vlist.io",
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@types/jsdom": "^27.0.0",
    "jsdom": "^28.0.0",
    "typescript": "^5.0.0"
  }
}
